{
  "id": "vibe-attendance-app",
  "name": "VIBE Attendance Tracker",
  "short_name": "Attendance",
  "description": "Smart employee check-in and check-out tracking system with real-time geolocation, offline support, and attendance analytics.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#0b0f1a",
  "theme_color": "#4f8ef7",
  "lang": "en",
  "dir": "ltr",
  "prefer_related_applications": false,
  "categories": ["business", "productivity"],
  
  "content_security_policy": {
    "base_uri": ["'self'"],
    "default_src": ["'self'"],
    "script_src": ["'self'"],
    "style_src": ["'self'", "'unsafe-inline'"],
    "img_src": ["'self'", "data:", "https:"],
    "font_src": ["'self'", "https://fonts.gstatic.com"],
    "connect_src": ["'self'", "https://script.google.com", "https://sheets.googleapis.com"],
    "frame_ancestors": ["'none'"],
    "form_action": ["'self'"]
  },

  "icons": [
    {
      "src": "favicon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "apple-touch-icon.png",
      "sizes": "180x180",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],

  "screenshots": [
    {
      "src": "screenshot-mobile.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Check in with real-time geolocation"
    },
    {
      "src": "screenshot-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Admin dashboard and attendance analytics"
    }
  ],

  "shortcuts": [
    {
      "name": "Check In",
      "short_name": "Check In",
      "description": "Mark your attendance for today",
      "url": "./index.html?action=checkin",
      "icons": [{ "src": "favicon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Check Out",
      "short_name": "Check Out",
      "description": "Mark your departure",
      "url": "./index.html?action=checkout",
      "icons": [{ "src": "favicon-96x96.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],

  "share_target": {
    "action": "./share",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
